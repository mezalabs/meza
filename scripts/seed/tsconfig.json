{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@meza/gen/*": ["../../client/gen/*"],
      "@meza/core/*": ["../../client/packages/core/src/*"]
    }
  },
  "include": ["src"]
}
