{
  "name": "meza-client",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "pnpm --filter @meza/web dev",
    "build": "pnpm -r build",
