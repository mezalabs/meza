---
import MezaLogo from '../MezaLogo.astro';
import { Image } from 'astro:assets';
import screenshot from '../../assets/images/app-screenshot.png';

const GITHUB_REPO = 'mezalabs/meza';
const RELEASES_URL = `https://github.com/${GITHUB_REPO}/releases`;

const platforms = [
  { os: 'macos', label: 'macOS', suffix: 'mac-arm64.dmg' },
  { os: 'windows', label: 'Windows', suffix: 'win-x64.exe' },
  { os: 'linux', label: 'Linux', suffix: 'linux-x86_64.AppImage' },
];

let version: string | null = null;
try {
  const res = await fetch(
    `https://api.github.com/repos/${GITHUB_REPO}/releases`,
    { headers: { Accept: 'application/vnd.github.v3+json' } },
  );
  if (res.ok) {
    const releases: Array<{
      tag_name: string;
      draft: boolean;
      prerelease: boolean;
    }> = await res.json();
    const desktop = releases.find(
      (r) => r.tag_name.startsWith('desktop-v') && !r.draft && !r.prerelease,
    );
    if (desktop) {
      version = desktop.tag_name.replace('desktop-v', '');
    }
  }
} catch {
  // Build-time fetch failed — fall back to generic download link
}
---

<section class="relative min-h-screen px-6 pt-24 pb-8 lg:flex lg:items-center lg:overflow-hidden">
  <div class="mx-auto w-full max-w-7xl">
    <!-- Copy + CTA -->
    <div class="relative z-10 max-w-lg">
      <MezaLogo class="mb-8 h-14 translate-x-2 text-accent sm:h-16" />

      <h1 class="text-3xl font-bold leading-tight tracking-tight text-text sm:text-4xl lg:text-5xl">
        Private conversations, zero compromises
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-relaxed text-text-muted sm:text-xl">
        End-to-end encrypted group chat with voice, video, and text.
        Open source and self-hostable. No tracking, no ads, ever.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col items-start gap-4">
        <div class="relative inline-flex w-full max-w-xs" id="download-group">
          {platforms.map((p) => {
            const href = version
              ? `https://github.com/${GITHUB_REPO}/releases/download/desktop-v${version}/Meza-${version}-${p.suffix}`
              : RELEASES_URL;
            return (
              <a
                href={href}
                data-os={p.os}
                class="download-btn hidden"
              >
                Download for {p.label}
              </a>
            );
          })}

          <a
            id="download-primary"
            href={RELEASES_URL}
            class="inline-flex flex-1 items-center justify-center rounded-l-lg bg-accent px-6 py-3.5 text-sm font-medium text-black transition-colors hover:bg-accent-hover"
          >
            Download Meza
          </a>

          <button
            type="button"
            id="download-toggle"
            class="inline-flex items-center rounded-r-lg border-l border-black/10 bg-accent px-3 py-3.5 text-black transition-colors hover:bg-accent-hover"
            aria-label="More download options"
            aria-expanded="false"
          >
            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <div
            id="download-dropdown"
            class="absolute top-full right-0 left-0 z-10 mt-2 hidden overflow-hidden rounded-lg border border-border bg-bg-surface shadow-lg"
          >
            {platforms.map((p) => {
              const href = version
                ? `https://github.com/${GITHUB_REPO}/releases/download/desktop-v${version}/Meza-${version}-${p.suffix}`
                : RELEASES_URL;
              return (
                <a
                  href={href}
                  data-os={p.os}
                  class="dropdown-item flex items-center px-4 py-3 text-sm text-text transition-colors hover:bg-bg-elevated"
                >
                  Download for {p.label}
                </a>
              );
            })}
            <a
              href={RELEASES_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center border-t border-border px-4 py-3 text-sm text-text-muted transition-colors hover:bg-bg-elevated"
            >
              View all downloads
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Screenshot — large, behind text on lg -->
    <div class="mt-12 lg:absolute lg:top-[5%] lg:bottom-[5%] lg:left-[35%] lg:right-[2%] lg:mt-0 lg:flex lg:items-center">
      <div class="overflow-hidden rounded-xl border border-border shadow-2xl">
        <Image
          src={screenshot}
          alt="Meza desktop app showing a chat conversation with voice channels"
          widths={[800, 1280, 1920]}
          sizes="(max-width: 1023px) 100vw, 75vw"
          format="png"
          quality={95}
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<script>
  const ua = navigator.userAgent.toLowerCase();
  let os = 'linux';
  if (ua.includes('mac')) os = 'macos';
  else if (ua.includes('win')) os = 'windows';

  const match = document.querySelector(`.download-btn[data-os="${os}"]`);
  const primary = document.getElementById('download-primary');
  if (match instanceof HTMLAnchorElement && primary instanceof HTMLAnchorElement) {
    primary.href = match.href;
    primary.textContent = match.textContent;
  }

  const toggle = document.getElementById('download-toggle');
  const dropdown = document.getElementById('download-dropdown');
  if (toggle && dropdown) {
    toggle.addEventListener('click', () => {
      const open = !dropdown.classList.contains('hidden');
      dropdown.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!open));
    });
    document.addEventListener('click', (e) => {
      if (!document.getElementById('download-group')?.contains(e.target as Node)) {
        dropdown.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
