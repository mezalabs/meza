---
const RELEASES_URL = 'https://github.com/mezalabs/meza/releases';
---

<section class="px-6 py-16 md:px-8 md:py-24">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="text-2xl font-bold text-text sm:text-3xl">
      Try it. Read the source. Host it yourself.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-text-muted">
      No signup wall, no credit card, no trust required — the code is right there.
    </p>

    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center md:mt-12">
      <a
        id="cta-download"
        href={RELEASES_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex w-full items-center justify-center rounded-lg bg-accent px-8 py-4 text-base font-medium text-black transition-colors hover:bg-accent-hover sm:w-auto"
      >
        Download Meza
      </a>
      <a
        href="https://app.meza.chat"
        class="inline-flex w-full items-center justify-center rounded-lg border border-border bg-bg-surface px-8 py-4 text-base font-medium text-text transition-colors hover:border-border-hover hover:bg-bg-elevated sm:w-auto"
      >
        Open in browser
      </a>
    </div>

    <p class="mt-6 text-sm text-text-subtle">
      Free and open source. Always.
    </p>
  </div>
</section>

<script>
  const ua = navigator.userAgent.toLowerCase();
  let os = 'linux';
  if (/android|iphone|ipad|ipod/.test(ua)) os = 'mobile';
  else if (ua.includes('mac')) os = 'macos';
  else if (ua.includes('win')) os = 'windows';

  const cta = document.getElementById('cta-download');
  if (cta instanceof HTMLAnchorElement) {
    if (os === 'mobile') {
      cta.href = 'https://github.com/mezalabs/meza';
      cta.textContent = 'View the code';
    } else {
      const match = document.querySelector(`.download-btn[data-os="${os}"]`);
      if (match instanceof HTMLAnchorElement) {
        cta.href = match.href;
        cta.textContent = match.textContent;
      }
    }
  }
</script>
