---

<section id="features" class="px-6 py-24">
  <div class="mx-auto max-w-6xl">
    <h2 class="mb-4 text-center text-2xl font-bold text-text sm:text-3xl">
      Built for privacy-first communities
    </h2>
    <p class="mx-auto mb-16 max-w-2xl text-center text-lg text-text-muted">
      Meza combines the privacy of Signal with the community features of Discord — without the trade-offs.
    </p>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((feature) => (
        <div class="rounded-xl border border-border bg-bg-surface p-6 transition-colors hover:border-border-hover">
          <div class="mb-4 text-accent" set:html={feature.icon} />
          <h3 class="mb-2 text-lg font-semibold text-text">{feature.title}</h3>
          <p class="text-sm leading-relaxed text-text-muted">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
