---

<section id="features" class="px-6 py-16 md:px-8 md:py-24">
  <div class="mx-auto max-w-6xl">
    <h2 class="mb-4 text-center text-2xl font-bold text-text sm:text-3xl">
      What you get
    </h2>
    <p class="mx-auto mb-16 max-w-2xl text-center text-lg text-text-muted md:mb-20">
      The community features you want, the privacy you deserve, none of the baggage.
    </p>

    <div class="grid gap-6 sm:grid-cols-2 md:gap-8 lg:grid-cols-3">
      {features.map((feature) => (
        <div class="rounded-xl border border-border bg-bg-surface p-6 transition-colors hover:border-border-hover">
          <div class="mb-4 text-accent" set:html={feature.icon} />
          <h3 class="mb-2 text-lg font-semibold text-text">{feature.title}</h3>
          <p class="text-sm leading-relaxed text-text-muted">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
