---
// Placeholder section — will be replaced with real device-frame mockups
---

<section class="px-6 py-24">
  <div class="mx-auto max-w-5xl">
    <h2 class="mb-4 text-center text-2xl font-bold text-text sm:text-3xl">
      A chat experience you'll love
    </h2>
    <p class="mx-auto mb-16 max-w-2xl text-center text-lg text-text-muted">
      Rich text, threads, voice channels, file sharing, and more — all end-to-end encrypted.
    </p>

    <!-- Placeholder mockup -->
    <div class="mx-auto max-w-4xl overflow-hidden rounded-xl border border-border bg-bg-surface shadow-lg">
      <div class="flex items-center gap-2 border-b border-border px-4 py-3">
        <div class="h-3 w-3 rounded-full bg-error/60"></div>
        <div class="h-3 w-3 rounded-full bg-warning/60"></div>
        <div class="h-3 w-3 rounded-full bg-success/60"></div>
        <span class="ml-2 text-xs text-text-subtle">Meza Desktop</span>
      </div>
      <div class="flex min-h-[400px]">
        <!-- Sidebar -->
        <div class="hidden w-56 border-r border-border bg-bg-overlay p-4 sm:block">
          <div class="mb-4 text-xs font-semibold uppercase tracking-wider text-text-subtle">Servers</div>
          <div class="space-y-2">
            <div class="rounded-md bg-bg-elevated px-3 py-2 text-sm text-accent">Meza Community</div>
            <div class="rounded-md px-3 py-2 text-sm text-text-muted">Design Team</div>
            <div class="rounded-md px-3 py-2 text-sm text-text-muted">Open Source</div>
          </div>
          <div class="mt-6 text-xs font-semibold uppercase tracking-wider text-text-subtle">Channels</div>
          <div class="mt-2 space-y-1">
            <div class="rounded-md bg-bg-elevated px-3 py-1.5 text-sm text-text"># general</div>
            <div class="rounded-md px-3 py-1.5 text-sm text-text-muted"># announcements</div>
            <div class="rounded-md px-3 py-1.5 text-sm text-text-muted"># development</div>
            <div class="rounded-md px-3 py-1.5 text-sm text-text-muted"># voice-chat</div>
          </div>
        </div>
        <!-- Chat area -->
        <div class="flex flex-1 flex-col p-4">
          <div class="flex-1 space-y-4">
            <div class="flex items-start gap-3">
              <div class="h-8 w-8 flex-shrink-0 rounded-full bg-accent-subtle"></div>
              <div>
                <div class="flex items-baseline gap-2">
                  <span class="text-sm font-semibold text-text">Alice</span>
                  <span class="text-xs text-text-subtle">2:34 PM</span>
                </div>
                <p class="mt-0.5 text-sm text-text-muted">Hey everyone! The new E2E encryption is working great.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="h-8 w-8 flex-shrink-0 rounded-full bg-info/30"></div>
              <div>
                <div class="flex items-baseline gap-2">
                  <span class="text-sm font-semibold text-text">Bob</span>
                  <span class="text-xs text-text-subtle">2:36 PM</span>
                </div>
                <p class="mt-0.5 text-sm text-text-muted">Love the voice channels too. Crystal clear audio!</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="h-8 w-8 flex-shrink-0 rounded-full bg-warning/30"></div>
              <div>
                <div class="flex items-baseline gap-2">
                  <span class="text-sm font-semibold text-text">Carol</span>
                  <span class="text-xs text-text-subtle">2:38 PM</span>
                </div>
                <p class="mt-0.5 text-sm text-text-muted">Self-hosting was surprisingly easy with Docker Compose.</p>
              </div>
            </div>
          </div>
          <div class="mt-4 rounded-lg border border-border bg-bg-elevated px-4 py-3 text-sm text-text-subtle">
            Message #general
          </div>
        </div>
      </div>
    </div>

    <!-- Platform badges -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4 text-sm text-text-muted">
      <span class="rounded-full border border-border px-4 py-1.5">Web</span>
      <span class="rounded-full border border-border px-4 py-1.5">macOS</span>
      <span class="rounded-full border border-border px-4 py-1.5">Windows</span>
      <span class="rounded-full border border-border px-4 py-1.5">Linux</span>
      <span class="rounded-full border border-border px-4 py-1.5">iOS</span>
      <span class="rounded-full border border-border px-4 py-1.5">Android</span>
    </div>
  </div>
</section>
