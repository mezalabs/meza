# Meza Development Environment
# Copy to .env: cp .env.example .env

# Common
MEZA_LISTEN_ADDR=:8080
MEZA_NATS_URL=nats://localhost:4222
MEZA_LOG_LEVEL=info

# Auth — Ed25519 keys (auto-generated by scripts/start.sh into .keys/)
# For standalone service runs, point these at your key files:
MEZA_JWT_PRIVATE_KEY_FILE=.keys/ed25519.pem
MEZA_ED25519_PUBLIC_KEY_FILE=.keys/ed25519_pub.pem
MEZA_HMAC_SECRET=dev-secret-change-in-production
# MEZA_JWT_KEY_ID=                # Key ID for JWKS kid field (optional, for key rotation)

# Federation
# MEZA_FEDERATION_ENABLED=false
# MEZA_ORIGIN_URL=https://meza.chat   # Single origin (identity provider)
# MEZA_INSTANCE_URL=                   # This instance's public URL (e.g. https://coolgroup.org)

# Database
MEZA_POSTGRES_URL=postgres://meza:meza@localhost:5432/meza?sslmode=disable
MEZA_SCYLLA_HOSTS=localhost:9042
MEZA_REDIS_URL=redis://localhost:6379

# Gateway
# Comma-separated WebSocket allowed origins. Defaults to "*" (wildcard) if unset.
# Production: set to your actual domain(s), e.g. https://app.example.com
MEZA_ALLOWED_ORIGINS=http://localhost:4080

# Media (S3-compatible / MinIO)
MEZA_S3_ENDPOINT=http://localhost:9000
# MEZA_S3_PUBLIC_ENDPOINT=         # Public-facing S3 URL for presigned URLs
                                    # For mobile dev: use the Vite HTTPS URL (e.g. https://192.168.x.x:4081)
                                    # so presigned URLs go through Vite's proxy to MinIO, avoiding mixed content.
MEZA_S3_BUCKET=meza-media
MEZA_S3_ACCESS_KEY=minioadmin
MEZA_S3_SECRET_KEY=minioadmin
# Comma-separated allowed origins for S3 bucket CORS (required for browser uploads/downloads)
# Production with mobile apps: include https://localhost (Capacitor WebView origin)
# For mobile dev, add your LAN origin: http://localhost:4080,https://<mac-ip>:4081
S3_CORS_ORIGINS=http://localhost:4080

# Voice (LiveKit)
MEZA_LIVEKIT_HOST=http://localhost:7880
# MEZA_LIVEKIT_PUBLIC_URL=  # URL sent to clients (defaults to LIVEKIT_HOST; for mobile dev: wss://<mac-ip>:4081)
MEZA_LIVEKIT_API_KEY=devkey
MEZA_LIVEKIT_API_SECRET=devsecret

# Notifications (Web Push / VAPID)
# Generate keys: npx web-push generate-vapid-keys
# MEZA_VAPID_PUBLIC_KEY=
# MEZA_VAPID_PRIVATE_KEY=
